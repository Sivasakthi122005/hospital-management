# Server Port
PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb://127.0.0.1:27017/hospital_db

# For production (MongoDB Atlas) use something like:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hospital_db

# JWT Secret Key (for authentication if you add login/register API)
JWT_SECRET=mysecretkey123

# Node Environment
NODE_ENV=development
